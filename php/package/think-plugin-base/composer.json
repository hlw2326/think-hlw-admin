{
  "type": "think-admin-plugin",
  "name": "hlw2326/think-plugin-base",
  "version": "1.0.3",
  "homepage": "https://www.hlw2326.com",
  "description": "测试通用插件",
  "license": "MIT",
  "authors": [
    {
      "name": "hlw2326",
      "email": "1608626143@qq.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-json": "*"
  },
  "autoload": {
    "files": [
      "./src/helper.php"
    ],
    "psr-4": {
      "plugin\\base\\": "src"
    }
  },
  "extra": {
    "think": {
      "services": [
        "plugin\\base\\Service"
      ]
    },
    "plugin": {
      "copy": {
        "stc/database": "database/migrations"
      }
    },
    "config": {
      "type": "module",
      "name": "通用插件",
      "document": "https://www.hlw2326.com",
      "description": "通用小程序管理插件",
      "license": []
    }
  }
}
