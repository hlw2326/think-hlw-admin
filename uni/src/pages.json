{
    "easycom": {
        "autoscan": true,
        "custom": {
            "^u-(.*)": "@/components/u-$1/u-$1.vue"
        }
    },
    "pages": [
        {
            "path": "pages/index/index",
            "style": {
                "navigationBarTitleText": "首页"
            }
        },
        {
            "path": "pages/user/index",
            "style": {
                "navigationBarTitleText": "我的"
            }
        },
        {
            "path": "pages/user/theme/index",
            "style": {
                "navigationBarTitleText": "主题设置"
            }
        },
        {
            "path": "pages/tools/index",
            "style": {
                "navigationBarTitleText": "工具"
            }
        },
        {
            "path": "pages/help/index",
            "style": {
                "navigationBarTitleText": "帮助"
            }
        }
    ],
    "tabBar": {
        "color": "#4f5567",
        "selectedColor": "#0074e1",
        "spacing": "6px",
        "height": "76px",
        "fontSize": "12px",
        "list": [
            {
                "pagePath": "pages/index/index",
                "text": "首页",
                "iconPath": "static/tabs/icon_home.png",
                "selectedIconPath": "static/tabs/icon_home_cur.png"
            },
            {
                "pagePath": "pages/tools/index",
                "text": "工具",
                "iconPath": "static/tabs/icon_tools.png",
                "selectedIconPath": "static/tabs/icon_tools_cur.png"
            },
            {
                "pagePath": "pages/user/index",
                "text": "我的",
                "iconPath": "static/tabs/icon_user.png",
                "selectedIconPath": "static/tabs/icon_user_cur.png"
            }
        ]
    },
    "globalStyle": {
        "navigationBarTextStyle": "black",
        "navigationBarTitleText": "通用",
        "navigationBarBackgroundColor": "#f8f8f8",
        "navigationStyle": "custom",
        "backgroundColor": "#F8F8F8"
    }
}
