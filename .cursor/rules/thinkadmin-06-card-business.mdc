## 六、卡密使用流程（Service 层）

卡密使用逻辑统一写在 `app\mini\service\CardUseService` 中。

### 积分卡密使用

```php
public static function useScoreCard(string $cardCode, int $userId): array
{
    // 1. 检查是否可用
    $canUse = MiniCardLog::canUseCard(MiniCardLog::TYPE_SCORE, $cardCode, $userId);
    if (!$canUse['can']) {
        return ['success' => false, 'message' => $canUse['reason']];
    }

    $card = MiniCardScore::mk()->where(['card_code' => $cardCode])->findOrEmpty();
    if (!$card->isExists()) {
        return ['success' => false, 'message' => '卡密不存在！'];
    }

    $user = MiniUser::mk()->where(['id' => $userId])->findOrEmpty();
    if (!$user->isExists()) {
        return ['success' => false, 'message' => '用户不存在！'];
    }

    try {
        \think\facade\Db::startTrans();

        // 2. 记录使用日志
        MiniCardLog::recordUse(
            MiniCardLog::TYPE_SCORE,
            $card->id,
            $cardCode,
            $userId,
            ['score' => $card->score]
        );

        // 3. 增加用户积分
        $currentScore = intval(MiniUser::mk()->where(['id' => $userId])->value('score') ?: 0);
        $newBalance = $currentScore + intval($card->score);
        MiniUser::mk()->where(['id' => $userId])->update(['score' => $newBalance]);

        // 4. 记录积分流水
        MiniUserScoreLog::record(
            $userId,
            intval($card->score),
            $newBalance,
            MiniUserScoreLog::SOURCE_CARD_SCORE,
            intval($card->id),
            '积分卡密充值：' . $cardCode
        );

        \think\facade\Db::commit();

        $stats = MiniCardLog::getCardUseStats($cardCode, MiniCardLog::TYPE_SCORE);

        return [
            'success' => true,
            'message' => '使用成功',
            'data'    => [
                'score'        => $card->score,
                'use_count'    => $stats['total_uses'],
                'unique_users' => $stats['unique_users'],
            ],
        ];
    } catch (\Exception $e) {
        \think\facade\Db::rollback();
        return ['success' => false, 'message' => '使用失败：' . $e->getMessage()];
    }
}
```

### 会员卡密使用

```php
public static function useVipCard(string $cardCode, int $userId): array
{
    // ... 检查逻辑同上 ...

    try {
        \think\facade\Db::startTrans();

        // 记录使用日志
        MiniCardLog::recordUse(
            MiniCardLog::TYPE_VIP,
            $card->id,
            $cardCode,
            $userId,
            ['days' => $card->days]
        );

        // 更新用户会员时间
        $now = time();
        $currentVipTime = intval($user->vip_time);
        // 已开通且未过期：累加；未开通或已过期：以当前时间为起点
        $newVipTime = ($currentVipTime > $now) ? ($currentVipTime + $card->days * 86400) : ($now + $card->days * 86400);
        MiniUser::mk()->where(['id' => $userId])->update(['vip_time' => $newVipTime]);

        \think\facade\Db::commit();

        return [
            'success' => true,
            'message' => '使用成功',
            'data'    => [
                'days'         => $card->days,
                'use_count'    => $stats['total_uses'],
                'unique_users' => $stats['unique_users'],
            ],
        ];
    } catch (\Exception $e) {
        \think\facade\Db::rollback();
        return ['success' => false, 'message' => '使用失败：' . $e->getMessage()];
    }
}
