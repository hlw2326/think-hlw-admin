## 七、使用记录模型方法

```php
/**
 * 检查卡密是否可以使用
 */
public static function canUseCard(int $cardType, string $cardCode, int $userId): array
{
    // ... 状态检查、过期检查、超限检查 ...
    return ['can' => true, 'reason' => ''];
}

/**
 * 记录卡密使用
 */
public static function recordUse(int $cardType, int $cardId, string $cardCode, int $userId, array $useData = []): bool
{
    $ip = request()->ip() ?: '0.0.0.0';
    return (bool)static::mk()->insert([
        'card_type'  => $cardType,
        'card_id'    => $cardId,
        'card_code'  => $cardCode,
        'user_id'    => $userId,
        'use_data'   => json_encode($useData, JSON_UNESCAPED_UNICODE),
        'ip_address' => $ip,
        'use_time'   => time(),
    ]);
}

/**
 * 获取卡密使用统计
 */
public static function getCardUseStats(string $cardCode, int $cardType): array
{
    $totalUses = static::mk()->where([
        'card_code' => $cardCode,
        'card_type' => $cardType,
    ])->count();
    $uniqueUsers = static::mk()->where([
        'card_code' => $cardCode,
        'card_type' => $cardType,
    ])->distinct(true)->count('user_id');
    return [
        'total_uses'  => $totalUses,
        'unique_users'=> $uniqueUsers,
    ];
}
```

