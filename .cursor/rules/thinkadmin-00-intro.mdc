## 七、常用类引用

```php
use think\admin\Controller;           // 控制器基类
use think\admin\Model;                // 模型基类
use think\admin\Service;             // 服务基类
use think\admin\helper\QueryHelper;   // 查询助手
use think\admin\service\AdminService; // 管理员服务
use think\admin\extend\CodeExtend;   // 编码扩展
use think\admin\extend\DataExtend;   // 数据扩展
use think\admin\extend\HttpExtend;   // HTTP 扩展
```
