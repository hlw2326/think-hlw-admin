## 三、广告模块列表页 JS 辅助函数

### 广告类型 badge

```javascript
$.adTypeLabel = (function () {
    var types = JSON.parse($('#AdTypesData').text());
    return function (type) {
        var item = types[type] || {label: type, 'class': 'layui-bg-gray'};
        return '<span class="layui-badge ' + item['class'] + '">' + item.label + '</span>';
    };
})();
```

### 小程序名称 badge

```javascript
$.mpName = (function () {
    var list = JSON.parse($('#MpListData').text());
    return function (appid) {
        return list[appid]
            ? '<span>' + list[appid] + '</span><span class="color-desc" style="font-size:11px">(' + appid + ')</span>'
            : appid;
    };
})();
```

### 完整使用示例（ad/index.html）

```html
<label class="layui-hide">
    <textarea id="AdTypesData">{:json_encode($ad_types, JSON_UNESCAPED_UNICODE)}</textarea>
</label>
<label class="layui-hide">
    <textarea id="MpListData">{:json_encode($mp_list, JSON_UNESCAPED_UNICODE)}</textarea>
</label>

<script>
    $.mpName = (function () { /* ... */ })();
    $.adTypeLabel = (function () { /* ... */ })();

    $(function () {
        $('#AdTable').layTable({
            even: true, height: 'full',
            sort: {field: 'sort', type: 'desc'},
            cols: [[
                {checkbox: true, fixed: true},
                {field: 'id', title: 'ID', width: 70, align: 'center', sort: true},
                {field: 'sort', title: '{:lang("排序")}', width: 120, align: 'center', templet: '#SortInputTpl'},
                {field: 'appid', title: '{:lang("所属小程序")}', width: 200, align: 'center', templet: '#MpNameTpl'},
                {field: 'name', title: '{:lang("广告名称")}', minWidth: 140},
                {field: 'unit_id', title: '{:lang("广告ID")}', minWidth: 220},
                {field: 'ad_type', title: '{:lang("广告类型")}', width: 175, align: 'center', templet: '#AdTypeTpl'},
                {field: 'position', title: '{:lang("位置标识")}', width: 150, align: 'center'},
                {field: 'status', title: '{:lang("状态")}', width: 110, align: 'center', templet: '#StatusSwitchTpl'},
                {field: 'create_at', title: '{:lang("创建时间")}', width: 160, align: 'center', sort: true},
                {toolbar: '#toolbar', title: '{:lang("操作面板")}', width: 300, align: 'left'}
            ]]
        });
        // ...
    });
</script>

<script type="text/html" id="AdTypeTpl">
    {{- $.adTypeLabel(d.ad_type) }}
</script>

<script type="text/html" id="MpNameTpl">
    {{- $.mpName(d.appid) }}
</script>
```

