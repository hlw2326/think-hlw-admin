## 九、列表页模板 JS 辅助函数

### 导出 Excel（require 方式）

```javascript
require(['excel'], function (excel) {
    excel.bind(function (data) {
        data.forEach(function (item, index) {
            data[index] = [
                item.id,
                item.name,
                item.status == 1 ? '{:lang("已启用")}' : '{:lang("已禁用")}',
                item.create_at
            ];
        });
        data.unshift(['ID', '{:lang("名称")}', '{:lang("状态")}', '{:lang("创建时间")}']);
        return this.withStyle(data, {
            A: 60, B: 150, C: 100, D: 170
        });
    }, '{:lang("导出标题")}' + '_' + layui.util.toDateString(Date.now(), 'yyyyMMdd_HHmmss'));
});
```

### 图片列（禁止单独定义模板块）

```javascript
{field: 'avatar_url', title: '{:lang("头像")}', width: 65, align: "center", templet: "<div>{{-$.layTable.showImage(d.avatar_url)}}</div>"}
```

